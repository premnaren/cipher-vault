    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-[var(--accent)] rounded-full mix-blend-multiply filter blur-[128px] opacity-10 pointer-events-none"></div>

    <script>
        let currentMode = 'login';

        function showToast(msg, type = 'info') {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            let colorClass = type === 'error' ? 'border-red-500/50 text-red-500 bg-red-900/10' : 
                             type === 'success' ? 'border-green-500/50 text-green-500 bg-green-900/10' : 
                             'border-[var(--primary)] text-[var(--primary)] bg-[var(--bg-panel)]';
            
            toast.className = `backdrop-blur-md border ${colorClass} px-4 py-3 rounded-lg shadow-2xl font-mono text-xs flex items-center gap-3 transform translate-x-[120%] transition-transform duration-300 pointer-events-auto`;
            toast.innerHTML = `<span class="tracking-wide">${msg}</span>`;
            
            container.appendChild(toast);
            setTimeout(() => toast.classList.remove('translate-x-[120%]'), 10);
            setTimeout(() => {
                toast.classList.add('translate-x-[120%]');
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        const themes = ['void', 'retro', 'zen', 'light']; 
        function initTheme() {
            const savedTheme = localStorage.getItem('app-theme') || 'void'; 
            document.documentElement.setAttribute('data-theme', savedTheme);
        }
        function cycleTheme() {
            const current = document.documentElement.getAttribute('data-theme');
            const next = themes[(themes.indexOf(current) + 1) % themes.length];
            document.documentElement.setAttribute('data-theme', next);
            localStorage.setItem('app-theme', next);
        }
        initTheme();

        function switchTab(mode) {
            if (currentMode === mode) return; 
            currentMode = mode;
            const tabLogin = document.getElementById('tabLogin');
            const tabRegister = document.getElementById('tabRegister');
            const btn = document.getElementById('submitBtn');
            const form = document.getElementById('authForm');

            document.getElementById('username').value = '';
            document.getElementById('password').value = '';

            form.classList.remove('animate-form-switch');
            void form.offsetWidth; 
            form.classList.add('animate-form-switch');

            if (mode === 'login') {
                tabLogin.className = "flex-1 py-2 text-[11px] font-medium tracking-widest font-mono text-[var(--bg-body)] bg-[var(--primary)] rounded-md transition-all shadow-sm z-10 relative";
                tabRegister.className = "flex-1 py-2 text-[11px] font-medium tracking-widest font-mono text-[var(--text-muted)] hover:text-[var(--text-main)] rounded-md transition-all z-10 relative bg-transparent";
                btn.innerText = "AUTHENTICATE";
            } else {
                tabRegister.className = "flex-1 py-2 text-[11px] font-medium tracking-widest font-mono text-[var(--bg-body)] bg-[var(--primary)] rounded-md transition-all shadow-sm z-10 relative";
                tabLogin.className = "flex-1 py-2 text-[11px] font-medium tracking-widest font-mono text-[var(--text-muted)] hover:text-[var(--text-main)] rounded-md transition-all z-10 relative bg-transparent";
                btn.innerText = "ESTABLISH IDENTITY";
            }
        }

        async function handleGoogleAuth(response) {
            showToast("Verifying Google Auth Matrix...", "info");
            try {
                const res = await fetch('/api/auth/google', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ credential: response.credential })
                });
                const data = await res.json();
                if (res.ok) {
                    localStorage.setItem('auth-token', data.token);
                    // NEW: Check if agent needs to choose a codename
                    if (data.setupComplete === false) {
                        showToast("New Agent Detected. Redirecting to Alias Setup...", "success");
                        setTimeout(() => { window.location.href = '/alias-setup.html'; }, 1000);
                    } else {
                        showToast("Access Granted.", "success");
                        setTimeout(() => { window.location.href = '/'; }, 800);
                    }
                } else {
                    showToast(data.message || "Google Auth rejected.", "error");
                }
            } catch (err) {
                showToast("Network protocol failure.", "error");
            }
        }

        async function handleAuth(e) {
            e.preventDefault();
            const user = document.getElementById('username').value.trim();
            const pass = document.getElementById('password').value.trim();
            const endpoint = currentMode === 'login' ? '/api/auth/login' : '/api/auth/register';
            const btn = document.getElementById('submitBtn');

            btn.disabled = true;
            try {
                const res = await fetch(endpoint, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ username: user, password: pass })
                });
                const data = await res.json();
                if (res.ok) {
                    if (currentMode === 'register') {
                        showToast("Identity established. Sign in now.", "success");
                        setTimeout(() => switchTab('login'), 1200);
                    } else {
                        showToast("Access Granted.", "success");
                        localStorage.setItem('auth-token', data.token);
                        // Standard login users have setupComplete: true by default
                        setTimeout(() => { window.location.href = '/'; }, 800);
                    }
                } else {
                    showToast(data.message || data.error || "Auth failed.", "error");
                }
            } catch (err) {
                showToast("Server unreachable.", "error");
            } finally {
                btn.disabled = false;
            }
        }
    </script>
</body>
</html>
