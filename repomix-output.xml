<body class="h-screen w-screen flex flex-col items-center justify-center relative overflow-hidden">

    <div id="toastContainer" class="fixed bottom-5 right-5 z-[200] flex flex-col gap-3 pointer-events-none"></div>

    <div class="fixed top-8 right-8 z-50">
        <button onclick="cycleTheme()" class="w-10 h-10 flex items-center justify-center rounded-full border border-[var(--border)] bg-[var(--bg-panel)] text-[var(--text-muted)] hover:text-[var(--primary)] hover:border-[var(--primary)] transition-all backdrop-blur text-sm" title="Switch Theme">
