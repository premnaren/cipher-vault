        <div class="flex items-center justify-center gap-4 opacity-60">
            <div class="h-px w-8 bg-[var(--text-muted)]"></div>
            <p class="font-mono text-[10px] tracking-[0.4em] uppercase text-[var(--text-muted)]">Authentication</p>
            <div class="h-px w-8 bg-[var(--text-muted)]"></div>
        </div>
    </div>

    <div id="authCard" class="w-full max-w-[420px] rounded-2xl relative overflow-hidden flex flex-col z-10">
        
        <div class="px-8 pt-8 pb-4">
            <div class="flex p-1 bg-black/20 rounded-lg border border-[var(--border)] relative">
                <button id="tabLogin" onclick="switchTab('login')" class="flex-1 py-2 text-[11px] font-medium tracking-widest font-mono text-[var(--bg-body)] bg-[var(--primary)] rounded-md transition-all shadow-sm z-10 relative">SIGN IN</button>
                <button id="tabRegister" onclick="switchTab('register')" class="flex-1 py-2 text-[11px] font-medium tracking-widest font-mono text-[var(--text-muted)] hover:text-[var(--text-main)] rounded-md transition-all z-10 relative bg-transparent">CREATE ID</button>
            </div>
        </div>

        <div class="px-8 pb-8 pt-2">
            <form id="authForm" onsubmit="handleAuth(event)" class="space-y-6 animate-form-switch">
                
                <div class="space-y-1">
                    <label class="text-[10px] text-[var(--text-muted)] tracking-widest uppercase ml-1">Identity Alias</label>
                    <input type="text" id="username" required autocomplete="off" class="w-full modern-input p-3 rounded-lg font-mono text-sm text-[var(--text-main)] focus:outline-none" placeholder="Enter your alias">
                </div>
                
                <div class="space-y-1">
