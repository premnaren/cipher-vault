        }
        applyTheme();

        async function finalizeAlias(e) {
            e.preventDefault();
            const alias = document.getElementById('newAlias').value.trim();
            const token = localStorage.getItem('auth-token');
            const btn = document.getElementById('confirmBtn');

            if (!alias) return;

            btn.innerText = "UPDATING MATRIX...";
            btn.disabled = true;

            try {
                const res = await fetch('/api/auth/update-alias', {
                    method: 'POST',
                    headers: { 
                        'Content-Type': 'application/json',
                        'auth-token': token 
                    },
                    body: JSON.stringify({ newUsername: alias })
                });

                const data = await res.json();
                if (res.ok) {
                    // Update token in case the backend issued a new one with the new name
                    if (data.token) localStorage.setItem('auth-token', data.token);
                    window.location.href = '/'; 
                } else {
                    alert(data.message || "Alias already taken by another agent.");
                    btn.innerText = "CONFIRM CODENAME";
                    btn.disabled = false;
                }
            } catch (err) {
                console.error("Setup error:", err);
                btn.innerText = "CONFIRM CODENAME";
                btn.disabled = false;
            }
        }
    </script>
</body>
</html>
