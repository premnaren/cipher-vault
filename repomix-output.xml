<!DOCTYPE html>
<html lang="en" data-theme="retro">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CryptPact | Secure Terminal</title>
    
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/crypto-js/4.2.0/crypto-js.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jsencrypt/3.3.2/jsencrypt.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@500;900&family=Rajdhani:wght@500;700&family=Space+Mono:ital,wght@0,400;0,700;1,400&family=Inter:wght@400;600;900&display=swap');
        
        /* EXACT PIGPEN FONT - Matches your reference image perfectly */
        @import url('https://fonts.cdnfonts.com/css/pigpen-cipher');

        /* --- THEME SYSTEM --- */
        :root[data-theme="retro"] { 
            --bg-body: #1c1b1a; --bg-panel: #262422; --primary: #ffb347; --accent: #d48839; --border: #57534e; 
            --text-main: #e7e5e4; --text-muted: #a8a29e; --glow: 0 0 15px rgba(255, 179, 71, 0.15); 
            --overlay: rgba(28, 27, 26, 0.8); --shadow-3d: 8px 8px 0px #443f3c; 
        }
        :root[data-theme="zen"] { 
            --bg-body: #0f172a; --bg-panel: #1e293b; --primary: #38bdf8; --accent: #818cf8; --border: #475569; 
            --text-main: #f1f5f9; --text-muted: #94a3b8; --glow: none; --overlay: rgba(15, 23, 42, 0.8); 
            --shadow-3d: 8px 8px 0px #334155; 
        }
        :root[data-theme="light"] { 
            --bg-body: #e5e5e5; --bg-panel: #ffffff; --primary: #2563eb; --accent: #db2777; --border: #a3a3a3; 
            --text-main: #171717; --text-muted: #525252; --glow: 0 4px 6px rgba(0,0,0,0.1); 
            --overlay: rgba(255, 255, 255, 0.9); --shadow-3d: 8px 8px 0px #737373; 
        }
        :root[data-theme="void"] { 
            --bg-body: #050508; --bg-panel: #0f1015; --primary: #00f3ff; --accent: #bc13fe; --border: #334155; 
            --text-main: #e2e8f0; --text-muted: #64748b; --glow: 0 0 20px rgba(0, 243, 255, 0.2); 
            --overlay: rgba(0, 0, 0, 0.85); --shadow-3d: 8px 8px 0px #1e293b; 
        }
        
        body { 
            background-color: var(--bg-body); color: var(--text-main); font-family: 'Inter', sans-serif; 
            background-image: radial-gradient(var(--border) 1px, transparent 1px); background-size: 30px 30px;
            transition: all 0.5s ease;
        }

        .orbitron { font-family: 'Orbitron', sans-serif; } 
        .mono { font-family: 'Space Mono', monospace; }
        
        /* CLASS TO APPLY TRUE PIGPEN SHAPES */
        .font-pigpen { font-family: 'Pigpen Cipher', sans-serif !important; letter-spacing: 4px; font-weight: normal; }

        .card-inner { transform-style: preserve-3d; }
        .perspective-container { perspective: 1200px; }

        #mainCard { border: 2px solid var(--border); box-shadow: var(--shadow-3d); transition: all 0.3s ease; }

        ::-webkit-scrollbar { width: 8px; } 
        ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; } 
        ::-webkit-scrollbar-thumb:hover { background: var(--primary); }

        .modal-bg { background: rgba(0, 0, 0, 0.85); -webkit-backdrop-filter: blur(5px); backdrop-filter: blur(5px); }
        * { transition: border-color 0.3s ease, background-color 0.3s ease, color 0.3s ease, box-shadow 0.3s ease; }
    </style>
</head>
<body class="h-screen w-screen flex flex-col overflow-hidden">

    <div id="toastContainer" class="fixed bottom-5 right-5 z-[200] flex flex-col gap-3 pointer-events-none"></div>

    <nav class="fixed top-0 w-full p-4 flex justify-between items-center z-50 bg-[var(--bg-panel)]/95 backdrop-blur border-b border-[var(--border)]">
        <div class="flex items-center gap-4">
            <button id="termBtn" onclick="showPage('terminal')" class="flex items-center gap-2 text-[var(--primary)] font-bold border border-[var(--primary)] bg-[var(--overlay)] px-5 py-2 rounded-full shadow-[var(--glow)] transition-all">
                <span class="tracking-[0.15em] text-xs font-mono">TERMINAL</span>
            </button>
            <button id="libBtn" onclick="showPage('library')" class="flex items-center gap-3 text-[var(--text-muted)] font-bold border border-transparent bg-transparent px-5 py-2 rounded-full hover:text-[var(--text-main)] transition-all">
                <span class="tracking-[0.15em] text-xs font-mono">VIDEO LIBRARY</span>
            </button>
            <button onclick="toggleVault(true)" class="flex items-center gap-2 text-[var(--accent)] font-bold border border-[var(--border)] bg-[var(--overlay)] px-5 py-2 rounded-full hover:border-[var(--primary)] hover:text-[var(--primary)] group">
                <span class="text-lg group-hover:animate-pulse">🔒</span> <span class="tracking-[0.15em] text-xs font-mono">VAULT</span>
            </button>
            <a href="/chat" class="flex items-center gap-2 text-[var(--primary)] font-bold border border-[var(--border)] bg-[var(--overlay)] px-5 py-2 rounded-full hover:border-[var(--primary)] hover:bg-[var(--primary)] hover:text-black transition-all">
                <span class="text-lg">💬</span> <span class="tracking-[0.15em] text-xs font-mono">CHAT</span>
            </a>
        </div>
        <div class="flex items-center gap-4">
            <button onclick="cycleTheme()" class="w-10 h-10 flex items-center justify-center rounded-full border border-[var(--border)] text-[var(--primary)] hover:bg-[var(--primary)] hover:text-[var(--bg-body)] transition-all" title="Switch Theme">🎨</button>
            <h1 class="text-2xl font-black tracking-widest hidden xl:block orbitron">Crypt<span class="text-[var(--primary)]">Pact</span></h1>
            <button onclick="logout()" class="px-4 py-2 border border-red-900/50 text-red-500 rounded text-xs font-bold hover:bg-red-900/20">LOGOUT</button>
        </div>
    </nav>

    <main id="terminalPage" class="flex-grow flex items-center justify-center p-4 pt-24 perspective-container h-full">
        <div id="mainCard" class="card-inner w-full max-w-5xl bg-[var(--bg-panel)] rounded-xl relative overflow-hidden flex flex-col max-h-full">
            
            <div class="p-6 border-b border-[var(--border)] flex justify-between items-center bg-[var(--overlay)] shrink-0">
                <div>
                    <h2 id="modeTitle" class="text-3xl font-bold tracking-widest orbitron text-[var(--primary)]">ENCRYPTION MODE</h2>
                    <p class="text-[10px] mono text-[var(--text-muted)]">SYSTEM STATUS: READY // AUTO-KEY MEMORY: <span id="memoryStatus" class="text-red-500 font-bold">OFFLINE</span></p>
                </div>
                <button id="swapModeBtn" class="flex items-center gap-3 px-6 py-3 bg-[var(--border)] hover:bg-[var(--primary)] hover:text-black transition-all rounded group">
                    <div class="text-right"><div class="text-[10px] font-bold uppercase opacity-50 text-[var(--text-main)]">Current Mode</div><div class="text-sm font-bold text-[var(--text-main)] group-hover:text-black" id="swapBtnText">ENCRYPT</div></div>
                    <svg class="w-6 h-6 group-hover:rotate-180 transition-transform duration-500 text-[var(--text-main)] group-hover:text-black" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4" /></svg>
                </button>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-0 flex-grow overflow-hidden">
                <div class="p-6 space-y-6 border-r border-[var(--border)] relative overflow-y-auto">
                    <div>
                        <label for="algoSelect" class="text-[10px] font-bold text-[var(--text-muted)] uppercase mb-2 block font-mono">Algorithm Selection</label>
                        <select id="algoSelect" title="Select Algorithm" aria-label="Select Algorithm" class="w-full bg-[var(--bg-body)] border border-[var(--border)] p-3 rounded text-sm font-bold focus:border-[var(--primary)] outline-none transition-colors text-[var(--text-main)] font-mono">
                            <optgroup label="Classical Ciphers">
                                <option value="atbash" selected>1. Atbash Cipher</option>
                                <option value="caesar">2. Caesar Cipher</option>
                                <option value="playfair">3. Playfair Cipher</option>
                                <option value="vigenere">4. Vigenère Cipher</option>
                                <option value="rail_fence">5. Rail Fence Cipher</option>
                                <option value="pigpen">6. Pigpen Cipher</option>
                            </optgroup>
                            <optgroup label="Modern Encryption">
                                <option value="aes">7. AES-256 (Standard)</option>
                                <option value="rsa">8. RSA (Asymmetric)</option>
                                <option value="ecc">9. ECC (Elliptic Curve)</option>
                            </optgroup>
                            <optgroup label="Covert Operations">
                                <option value="steganography">10. Steganography (Image)</option>
                            </optgroup>
                        </select>
                    </div>

                    <div id="dynamicInputs" class="space-y-4">
                        <div id="stdInputGroup">
                            <label class="text-[10px] font-bold text-[var(--text-muted)] uppercase mb-2 block font-mono">Input Data</label>
                            <textarea id="mainInput" title="Enter Text to Encrypt" aria-label="Enter Text to Encrypt" class="w-full h-32 bg-[var(--bg-body)] border border-[var(--border)] p-3 rounded mono text-sm focus:border-[var(--primary)] outline-none resize-none text-[var(--text-main)] placeholder-[var(--text-muted)] transition-all" placeholder="Enter text..."></textarea>
                            
                            <div id="pigpenKeyboard" class="hidden mt-3 grid-cols-7 gap-1 p-3 rounded-lg border border-[var(--border)] bg-[var(--overlay)] shadow-inner">
                                </div>
                        </div>

                        <div id="stegoInputGroup" class="hidden">
                            <label class="text-[10px] font-bold text-[var(--accent)] uppercase mb-2 block font-mono">Image Source</label>
                            <input type="file" id="stegoFile" title="Upload Source Image" aria-label="Upload Source Image" accept="image/png" class="w-full text-xs text-[var(--text-muted)] file:bg-[var(--accent)] file:text-black file:border-0 file:px-2 file:py-1 file:rounded file:font-bold mb-2">
                            <div id="stegoTextContainer">
                                <label class="text-[10px] font-bold text-[var(--text-muted)] uppercase mb-2 block font-mono">Secret Payload</label>
                                <textarea id="stegoPayload" title="Enter Secret Message" aria-label="Enter Secret Message" class="w-full h-20 bg-[var(--bg-body)] border border-[var(--border)] p-3 rounded mono text-sm focus:border-[var(--accent)] outline-none text-[var(--text-main)]" placeholder="Message to hide..."></textarea>
                            </div>
                        </div>

                        <div id="keyGroup">
                            <label id="keyLabel" class="text-[10px] font-bold text-[var(--text-muted)] uppercase mb-2 block font-mono">Encryption Key</label>
                            <input id="keyInput" type="text" title="Enter Encryption Key" aria-label="Enter Encryption Key" class="w-full bg-[var(--bg-body)] border border-[var(--border)] p-3 rounded mono text-[var(--primary)] focus:border-[var(--primary)] outline-none placeholder-[var(--text-muted)] text-[var(--text-main)]" placeholder="Key / Shift / Password">
                            <textarea id="rsaKeyInput" title="RSA Key Input" aria-label="RSA Key Input" class="hidden w-full h-24 bg-[var(--bg-body)] border border-[var(--border)] p-2 rounded mono text-[10px] text-[var(--primary)] focus:border-[var(--primary)] outline-none" placeholder="Paste Key Here... (Leave empty to Auto-Generate on Encrypt)"></textarea>
                        </div>

                        <button id="processBtn" class="w-full py-4 bg-[var(--primary)] text-black font-black tracking-widest rounded hover:shadow-[0_0_20px_var(--primary)] transition-all orbitron">
                            EXECUTE PROCESS
                        </button>
                    </div>
                </div>

                <div class="p-6 bg-[var(--overlay)] flex flex-col h-full relative overflow-y-auto">
                    <div class="flex justify-between items-center mb-4"> 
                        <label class="text-[10px] font-bold text-[var(--text-muted)] uppercase block font-mono">System Output</label> 
                        <button id="copyBtn" class="flex items-center gap-2 px-3 py-1 border border-[var(--primary)] text-[var(--primary)] hover:bg-[var(--primary)] hover:text-black transition-all rounded text-[10px] font-bold font-mono group">
                            <span>COPY RESULT</span>
                        </button>
                    </div>
                    <div class="flex-grow bg-[var(--bg-body)] border border-[var(--border)] rounded p-4 mono text-sm text-[var(--accent)] break-all whitespace-pre-wrap overflow-y-auto relative transition-all" id="outputWrapper">
                        <div id="outputDisplay">// WAITING FOR INPUT...</div>
                        <canvas id="stegoCanvas" class="hidden"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <main id="libraryPage" class="hidden flex-grow pt-24 px-4 pb-12 overflow-y-auto h-full">
        <div class="w-full max-w-7xl mx-auto">
            <div class="text-center mb-10">
                <h2 class="text-4xl orbitron text-[var(--primary)] mb-2 tracking-widest">CIPHER <span class="text-[var(--text-main)]">ARSENAL</span></h2>
                <p class="text-[var(--text-muted)] font-mono text-xs tracking-[0.3em]">VIDEO TUTORIAL DATABASE</p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 pb-20">
                <div class="border border-[var(--border)] bg-[var(--overlay)] p-4 rounded-xl hover:border-[var(--primary)]"><h3 class="text-lg orbitron text-[var(--text-main)] mb-2">1. ATBASH</h3><div class="aspect-video w-full border border-gray-700 bg-black"><iframe title="Atbash Tutorial" class="w-full h-full" src="https://www.youtube.com/embed/zt5Ax2TmZJI" frameborder="0" allowfullscreen></iframe></div></div>
                <div class="border border-[var(--border)] bg-[var(--overlay)] p-4 rounded-xl hover:border-[var(--primary)]"><h3 class="text-lg orbitron text-[var(--text-main)] mb-2">2. CAESAR</h3><div class="aspect-video w-full border border-gray-700 bg-black"><iframe title="Caesar Tutorial" class="w-full h-full" src="https://www.youtube.com/embed/JtbKh_12ctg" frameborder="0" allowfullscreen></iframe></div></div>
                <div class="border border-[var(--border)] bg-[var(--overlay)] p-4 rounded-xl hover:border-[var(--primary)]"><h3 class="text-lg orbitron text-[var(--text-main)] mb-2">3. PLAYFAIR</h3><div class="aspect-video w-full border border-gray-700 bg-black"><iframe title="Playfair Tutorial" class="w-full h-full" src="https://www.youtube.com/embed/1q37X_y9-lc" frameborder="0" allowfullscreen></iframe></div></div>
                <div class="border border-[var(--border)] bg-[var(--overlay)] p-4 rounded-xl hover:border-[var(--primary)]"><h3 class="text-lg orbitron text-[var(--text-main)] mb-2">4. VIGENERE</h3><div class="aspect-video w-full border border-gray-700 bg-black"><iframe title="Vigenere Tutorial" class="w-full h-full" src="https://www.youtube.com/embed/SkJcmCaHqS0" frameborder="0" allowfullscreen></iframe></div></div>
                <div class="border border-[var(--border)] bg-[var(--overlay)] p-4 rounded-xl hover:border-[var(--primary)]"><h3 class="text-lg orbitron text-[var(--text-main)] mb-2">5. RAIL FENCE</h3><div class="aspect-video w-full border border-gray-700 bg-black"><iframe title="Rail Fence Tutorial" class="w-full h-full" src="https://www.youtube.com/embed/wKjRwJTXQH4" frameborder="0" allowfullscreen></iframe></div></div>
                <div class="border border-[var(--border)] bg-[var(--overlay)] p-4 rounded-xl hover:border-[var(--primary)]"><h3 class="text-lg orbitron text-[var(--text-main)] mb-2">6. PIGPEN</h3><div class="aspect-video w-full border border-gray-700 bg-black"><iframe title="Pigpen Tutorial" class="w-full h-full" src="https://www.youtube.com/embed/vZrTJOhALmA" frameborder="0" allowfullscreen></iframe></div></div>
                <div class="border border-[var(--border)] bg-[var(--overlay)] p-4 rounded-xl hover:border-[var(--primary)]"><h3 class="text-lg orbitron text-[var(--text-main)] mb-2">7. AES-256</h3><div class="aspect-video w-full border border-gray-700 bg-black"><iframe title="AES Tutorial" class="w-full h-full" src="https://www.youtube.com/embed/O4xNJsjtN6E" frameborder="0" allowfullscreen></iframe></div></div>
                <div class="border border-[var(--border)] bg-[var(--overlay)] p-4 rounded-xl hover:border-[var(--primary)]"><h3 class="text-lg orbitron text-[var(--text-main)] mb-2">8. RSA</h3><div class="aspect-video w-full border border-gray-700 bg-black"><iframe title="RSA Tutorial" class="w-full h-full" src="https://www.youtube.com/embed/4zahvcJ9glg" frameborder="0" allowfullscreen></iframe></div></div>
                <div class="border border-[var(--border)] bg-[var(--overlay)] p-4 rounded-xl hover:border-[var(--primary)]"><h3 class="text-lg orbitron text-[var(--text-main)] mb-2">9. ECC</h3><div class="aspect-video w-full border border-gray-700 bg-black"><iframe title="ECC Tutorial" class="w-full h-full" src="https://www.youtube.com/embed/NF1pwjL9-DE" frameborder="0" allowfullscreen></iframe></div></div>
                <div class="border border-[var(--accent)] bg-[var(--overlay)] p-4 rounded-xl hover:border-[var(--text-main)] transition-all"><h3 class="text-lg orbitron text-[var(--accent)] mb-2">10. STEGANOGRAPHY</h3><div class="aspect-video w-full border border-gray-700 bg-black"><iframe title="Steganography Tutorial" class="w-full h-full" src="https://www.youtube.com/embed/TWEXCYQKyDc" frameborder="0" allowfullscreen></iframe></div></div>
            </div>
        </div>
    </main>

    <div id="vaultModal" class="fixed inset-0 z-[80] flex items-center justify-center hidden opacity-0 transition-opacity duration-300 pointer-events-none modal-bg">
        <div class="relative bg-[var(--bg-panel)] border border-[var(--primary)] w-full max-w-4xl rounded-xl shadow-[0_0_50px_var(--glow)] flex flex-col h-[600px] md:h-auto p-6">
            <div class="flex justify-between items-center mb-6 border-b border-[var(--border)] pb-4">
                <h3 class="text-2xl font-black tracking-widest text-[var(--accent)] orbitron">ZERO-KNOWLEDGE <span class="text-[var(--primary)]">VAULT</span></h3>
                <button onclick="toggleVault(false)" class="text-[var(--text-muted)] hover:text-white font-mono text-xl">✕</button>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div class="col-span-1 bg-white/5 border border-white/10 rounded p-6">
                    <label class="text-xs font-mono text-[var(--primary)] mb-2 block tracking-widest">1. SELECT ASSET</label>
                    <input type="file" id="vaultInput" title="File Upload" aria-label="File Upload" 
                           onchange="this.classList.add('border-[var(--primary)]', 'shadow-[0_0_10px_var(--glow)]')"
                           class="w-full text-xs text-[var(--text-muted)] mb-4 border border-[var(--border)] rounded p-2 transition-all duration-200
                                  file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 
                                  file:text-xs file:font-black file:bg-[var(--primary)] file:text-black 
                                  file:cursor-pointer file:transition-transform file:active:scale-90 hover:file:bg-white">
                    <label class="text-xs font-mono text-[var(--accent)] mb-2 block tracking-widest">2. PASSWORD</label>
                    <input type="password" id="vaultPass" title="Vault Password" aria-label="Vault Password" placeholder="Required" class="w-full bg-black border border-[var(--border)] text-xs text-[var(--accent)] p-2 rounded mb-4 focus:border-[var(--accent)] outline-none">
                    <button onclick="uploadEncryptedFile()" class="w-full py-3 bg-[var(--accent)] text-black font-black tracking-widest rounded hover:shadow-[0_0_15px_var(--accent)] font-mono text-xs">ENCRYPT & UPLOAD</button>
                </div>
                <div class="col-span-2 bg-white/5 border border-white/10 rounded p-6 flex flex-col h-[400px]">
                    <div class="flex justify-between items-center mb-4 border-b border-[var(--border)] pb-2">
                        <label class="text-xs font-mono text-[var(--primary)] tracking-widest">SECURE DATABASE</label>
                        <button onclick="loadFiles()" class="text-[10px] text-[var(--text-muted)] hover:text-white font-mono">↻ REFRESH</button>
                    </div>
                    <div id="vaultList" class="flex-grow overflow-y-auto pr-2 space-y-2"></div>
                </div>
            </div>
        </div>
    </div>

    <div id="passwordModal" class="fixed inset-0 z-[100] flex items-center justify-center hidden opacity-0 transition-opacity duration-300 pointer-events-none modal-bg">
        <div class="relative bg-[var(--bg-panel)] border border-[var(--primary)] w-96 rounded-xl shadow-[0_0_50px_var(--glow)] p-6 text-center transform scale-95 transition-transform duration-200">
            <h3 class="text-xl font-bold text-[var(--primary)] orbitron mb-4 tracking-widest">SECURITY CHECK</h3>
            <p class="text-[10px] text-[var(--text-muted)] font-mono mb-4 uppercase">Enter Decryption Key to Access File</p>
            <input type="password" id="passwordModalInput" class="w-full bg-[var(--bg-body)] border border-[var(--border)] text-[var(--primary)] p-3 rounded mb-6 text-center font-mono focus:border-[var(--primary)] outline-none transition-all" placeholder="••••••••" autocomplete="off">
            <div class="flex gap-3">
                <button id="passwordModalCancel" class="flex-1 py-2 border border-red-900/50 text-red-500 rounded font-bold hover:bg-red-900/20 text-xs tracking-widest font-mono">CANCEL</button>
                <button id="passwordModalSubmit" class="flex-1 py-2 bg-[var(--primary)] text-black rounded font-bold hover:bg-white text-xs tracking-widest shadow-[0_0_10px_var(--glow)] font-mono">UNLOCK</button>
            </div>
        </div>
    </div>

    <div id="confirmModal" class="fixed inset-0 z-[100] flex items-center justify-center hidden opacity-0 transition-opacity duration-300 pointer-events-none modal-bg">
        <div class="relative bg-[var(--bg-panel)] border border-red-500 w-96 rounded-xl shadow-[0_0_50px_rgba(239,68,68,0.2)] p-6 text-center transform scale-95 transition-transform duration-200">
            <h3 class="text-xl font-bold text-red-500 orbitron mb-4 tracking-widest">SYSTEM ALERT</h3>
            <p id="confirmModalText" class="text-xs text-[var(--text-main)] font-mono mb-6 uppercase">Are you sure?</p>
            <div class="flex gap-3">
                <button id="confirmModalCancel" class="flex-1 py-2 border border-[var(--border)] text-[var(--text-muted)] rounded font-bold hover:bg-[var(--bg-body)] text-xs tracking-widest font-mono transition-all">CANCEL</button>
                <button id="confirmModalSubmit" class="flex-1 py-2 bg-red-600 text-white rounded font-bold hover:bg-red-500 text-xs tracking-widest shadow-[0_0_10px_rgba(239,68,68,0.5)] font-mono transition-all">CONFIRM</button>
            </div>
        </div>
    </div>

    <script>
        const token = localStorage.getItem('auth-token');
        if (!token) window.location.href = '/login.html';
        function logout() { localStorage.removeItem('auth-token'); window.location.href = '/login.html'; }

        // --- CUSTOM TOAST NOTIFICATION SYSTEM ---
        function showToast(msg, type = 'info') {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            
            let colorClass = 'border-[var(--primary)] text-[var(--primary)]';
            let icon = 'ℹ️';
            
            if (type === 'error') {
                colorClass = 'border-red-500 text-red-500 bg-red-900/10';
                icon = '⚠️';
            } else if (type === 'success') {
                colorClass = 'border-green-500 text-green-500 bg-green-900/10';
                icon = '✅';
            } else {
                colorClass = 'border-[var(--primary)] text-[var(--primary)] bg-[var(--bg-body)]';
            }

            toast.className = `bg-[var(--bg-panel)] border ${colorClass} p-3 rounded shadow-[0_0_15px_currentColor] font-mono text-xs flex items-center gap-3 transform translate-x-[120%] transition-transform duration-300 pointer-events-auto backdrop-blur-md`;
            toast.innerHTML = `<span class="text-lg">${icon}</span> <span>${msg}</span>`;
            
            container.appendChild(toast);
            setTimeout(() => toast.classList.remove('translate-x-[120%]'), 10);
            setTimeout(() => {
                toast.classList.add('translate-x-[120%]');
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        // --- CUSTOM CONFIRMATION PROMPT ---
        function askConfirm(msg) {
            return new Promise((resolve) => {
                const modal = document.getElementById('confirmModal');
                const content = modal.firstElementChild; 
                const text = document.getElementById('confirmModalText');
                const submitBtn = document.getElementById('confirmModalSubmit');
                const cancelBtn = document.getElementById('confirmModalCancel');

                text.innerText = msg;
                modal.classList.remove('hidden', 'pointer-events-none');
                setTimeout(() => { modal.classList.remove('opacity-0'); content.classList.remove('scale-95'); content.classList.add('scale-100'); }, 10);

                const cleanup = () => {
                    modal.classList.add('opacity-0'); content.classList.remove('scale-100'); content.classList.add('scale-95');
                    setTimeout(() => { modal.classList.add('hidden', 'pointer-events-none'); }, 300);
                    submitBtn.onclick = null; cancelBtn.onclick = null;
                };

                submitBtn.onclick = () => { cleanup(); resolve(true); };
                cancelBtn.onclick = () => { cleanup(); resolve(false); };
            });
        }

        const themes = ['retro', 'light', 'zen', 'void'];
        let currentThemeIndex = 0;

        function initTheme() {
            const savedTheme = localStorage.getItem('app-theme') || 'retro'; 
            document.documentElement.setAttribute('data-theme', savedTheme);
            currentThemeIndex = themes.indexOf(savedTheme);
            if(currentThemeIndex === -1) currentThemeIndex = 0;
        }

        function cycleTheme() {
            currentThemeIndex = (currentThemeIndex + 1) % themes.length;
            const newTheme = themes[currentThemeIndex];
            document.documentElement.setAttribute('data-theme', newTheme);
            localStorage.setItem('app-theme', newTheme);
        }
        initTheme();

        let mode = 'encrypt';
        const keyCache = { rsa: null, aes: null };

        const DOM = {
            card: document.getElementById('mainCard'),
            algo: document.getElementById('algoSelect'),
            mainIn: document.getElementById('mainInput'),
            keyIn: document.getElementById('keyInput'),
            rsaKeyIn: document.getElementById('rsaKeyInput'),
            out: document.getElementById('outputDisplay'),
            outWrap: document.getElementById('outputWrapper'),
            swapBtn: document.getElementById('swapModeBtn'),
            modeTitle: document.getElementById('modeTitle'),
            btnText: document.getElementById('swapBtnText'),
            processBtn: document.getElementById('processBtn'),
            stdGroup: document.getElementById('stdInputGroup'),
            stegoGroup: document.getElementById('stegoInputGroup'),
            keyGroup: document.getElementById('keyGroup'),
            keyLabel: document.getElementById('keyLabel'),
            pigpenKb: document.getElementById('pigpenKeyboard'),
            stegoFile: document.getElementById('stegoFile'),
            stegoPayload: document.getElementById('stegoPayload'),
            stegoTextCont: document.getElementById('stegoTextContainer'),
            memStatus: document.getElementById('memoryStatus')
        };

        // --- BUILD PIGPEN VIRTUAL KEYBOARD (Uses A-Z and true font CSS) ---
        let kbHTML = `<div class="col-span-7 text-[9px] text-[var(--primary)] font-mono text-center mb-2 uppercase tracking-widest border-b border-[var(--border)] pb-2">Virtual Symbol Pad</div>`;
        "ABCDEFGHIJKLMNOPQRSTUVWXYZ".split('').forEach(sym => {
            kbHTML += `<button type="button" onclick="document.getElementById('mainInput').value += '${sym}'" class="p-2 bg-[var(--bg-body)] border border-[var(--border)] hover:bg-[var(--primary)] hover:text-[var(--bg-body)] rounded-md text-2xl transition-all flex items-center justify-center font-pigpen shadow-md h-12">${sym}</button>`;
        });
        kbHTML += `<button type="button" onclick="document.getElementById('mainInput').value += ' '" class="col-span-4 p-2 mt-1 bg-[var(--bg-body)] border border-[var(--border)] hover:bg-[var(--primary)] hover:text-black rounded text-xs font-mono transition-all font-bold tracking-widest h-10">SPACE</button>`;
        kbHTML += `<button type="button" onclick="document.getElementById('mainInput').value = document.getElementById('mainInput').value.slice(0, -1)" class="col-span-3 p-2 mt-1 bg-[var(--bg-body)] border border-red-900/50 text-red-500 hover:bg-red-500 hover:text-white rounded text-xs font-mono transition-all font-bold tracking-widest h-10">⌫ DEL</button>`;
        DOM.pigpenKb.innerHTML = kbHTML;

        function showPage(page) {
            const term = document.getElementById('terminalPage');
            const lib = document.getElementById('libraryPage');
            const termBtn = document.getElementById('termBtn');
            const libBtn = document.getElementById('libBtn');

            if(page === 'terminal') {
                term.classList.remove('hidden'); term.classList.add('flex');
                lib.classList.add('hidden');
                termBtn.className = "flex items-center gap-2 text-[var(--primary)] font-bold border border-[var(--primary)] bg-[var(--overlay)] px-5 py-2 rounded-full shadow-[var(--glow)] transition-all";
                libBtn.className = "flex items-center gap-3 text-[var(--text-muted)] font-bold border border-transparent bg-transparent px-5 py-2 rounded-full hover:text-[var(--text-main)] transition-all";
            } else {
                term.classList.add('hidden'); term.classList.remove('flex');
                lib.classList.remove('hidden');
                libBtn.className = "flex items-center gap-3 text-[var(--primary)] font-bold border border-[var(--border)] bg-[var(--overlay)] px-5 py-2 rounded-full transition-all";
                termBtn.className = "flex items-center gap-2 text-[var(--text-muted)] font-bold border border-transparent bg-transparent px-5 py-2 rounded-full hover:text-[var(--text-main)] transition-all";
            }
        }

        const letters = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789!@#$%^&*()_+";
        function animateText(element, finalState) {
            let iterations = 0;
            const interval = setInterval(() => {
                element.innerText = finalState.split("").map((letter, index) => {
                    if(index < iterations) return finalState[index];
                    return letters[Math.floor(Math.random() * 26)];
                }).join("");
                if(iterations >= finalState.length) { clearInterval(interval); element.innerText = finalState; }
                iterations += 1;
            }, 5);
        }

        function updateMemoryStatus() {
            if (keyCache.rsa || keyCache.aes) {
                DOM.memStatus.innerText = "ACTIVE"; DOM.memStatus.className = "text-green-500 font-bold animate-pulse";
            } else { DOM.memStatus.innerText = "OFFLINE"; DOM.memStatus.className = "text-red-500 font-bold"; }
        }

        DOM.swapBtn.onclick = () => {
            gsap.to(DOM.card, { rotationY: 90, duration: 0.2, onComplete: () => {
                mode = mode === 'encrypt' ? 'decrypt' : 'encrypt';
                DOM.modeTitle.innerText = mode === 'encrypt' ? "ENCRYPTION MODE" : "DECRYPTION MODE";
                DOM.modeTitle.style.color = mode === 'encrypt' ? "var(--primary)" : "#ff2a2a";
                DOM.btnText.innerText = mode === 'encrypt' ? "ENCRYPT" : "DECRYPT";
                DOM.processBtn.innerText = mode === 'encrypt' ? "EXECUTE ENCRYPTION" : "EXECUTE DECRYPTION";
                DOM.processBtn.style.backgroundColor = mode === 'encrypt' ? "var(--primary)" : "#ff2a2a";
                DOM.out.innerText = "// WAITING FOR INPUT...";
                
                DOM.mainIn.value = "";
                DOM.keyIn.value = "";
                DOM.rsaKeyIn.value = "";
                DOM.stegoPayload.value = "";
                DOM.stegoFile.value = "";

                DOM.algo.dispatchEvent(new Event('change'));

                gsap.to(DOM.card, { rotationY: 0, duration: 0.3 });
            }});
        };

        DOM.algo.addEventListener('change', () => {
            const val = DOM.algo.value;
            const isStego = val === 'steganography';
            const isRSA = val === 'rsa';
            
            const noKeyCiphers = ['atbash', 'pigpen', 'ecc', 'steganography', 'rsa'];
            
            DOM.stdGroup.classList.toggle('hidden', isStego);
            DOM.stegoGroup.classList.toggle('hidden', !isStego);
            
            if (noKeyCiphers.includes(val) && !isRSA) {
                DOM.keyGroup.classList.add('hidden');
            } else {
                DOM.keyGroup.classList.remove('hidden');
            }
            
            // Apply True Pigpen Font CSS Based on Mode
            if (val === 'pigpen') {
                if (mode === 'decrypt') {
                    DOM.pigpenKb.classList.remove('hidden'); DOM.pigpenKb.classList.add('grid');
                    DOM.mainIn.classList.add('font-pigpen', 'text-2xl');
                    DOM.mainIn.placeholder = ""; 
                    DOM.outWrap.classList.remove('font-pigpen', 'text-3xl');
                } else {
                    DOM.pigpenKb.classList.add('hidden'); DOM.pigpenKb.classList.remove('grid');
                    DOM.mainIn.classList.remove('font-pigpen', 'text-2xl');
                    DOM.mainIn.placeholder = "Enter text to convert to symbols...";
                    DOM.outWrap.classList.add('font-pigpen', 'text-3xl');
                }
            } else {
                DOM.pigpenKb.classList.add('hidden'); DOM.pigpenKb.classList.remove('grid');
                DOM.mainIn.classList.remove('font-pigpen', 'text-2xl');
                DOM.mainIn.placeholder = "Enter text...";
                DOM.outWrap.classList.remove('font-pigpen', 'text-3xl');
            }

            if (isRSA) { 
                DOM.keyIn.classList.add('hidden'); 
                DOM.rsaKeyIn.classList.remove('hidden'); 
                DOM.keyLabel.innerText = "RSA PUBLIC/PRIVATE KEY";
                DOM.rsaKeyIn.placeholder = (mode === 'decrypt' && keyCache.rsa) ? "[ACCESSING CACHED PRIVATE KEY...]" : (mode === 'encrypt' ? "Paste Public Key... (Leave blank to Auto-Generate)" : "Paste Private Key...");
            } else { 
                DOM.keyIn.classList.remove('hidden'); 
                DOM.rsaKeyIn.classList.add('hidden'); 
            }

            if (val === 'caesar') { DOM.keyLabel.innerText = "SHIFT VALUE (NUMBER)"; DOM.keyIn.placeholder = "e.g., 3"; } 
            else if (val === 'vigenere' || val === 'playfair') { DOM.keyLabel.innerText = "KEYWORD (LETTERS ONLY)"; DOM.keyIn.placeholder = "e.g., SECRET"; } 
            else if (val === 'rail_fence') { DOM.keyLabel.innerText = "NUMBER OF RAILS (NUMBER > 1)"; DOM.keyIn.placeholder = "e.g., 3"; } 
            else if (val === 'aes') { DOM.keyLabel.innerText = "ENCRYPTION PASSWORD / KEY"; DOM.keyIn.placeholder = (mode === 'decrypt' && keyCache.aes) ? "[ACCESSING CACHED KEY...]" : "Enter secure password..."; }

            DOM.out.innerText = "// WAITING...";
            if(val === 'ecc') DOM.processBtn.innerText = "GENERATE CURVE KEYS (SIMULATION)";
            else if (isStego) DOM.processBtn.innerText = mode === 'encrypt' ? "ENCODE & DOWNLOAD" : "DECODE IMAGE";
            else DOM.processBtn.innerText = mode === 'encrypt' ? "EXECUTE ENCRYPTION" : "EXECUTE DECRYPTION";
            
            DOM.modeTitle.innerText = isStego ? "STEGANOGRAPHY LAB" : (mode === 'encrypt' ? "ENCRYPTION MODE" : "DECRYPTION MODE");
            DOM.modeTitle.style.color = isStego ? "var(--accent)" : (mode === 'encrypt' ? "var(--primary)" : "#ff2a2a");
        });

        DOM.algo.dispatchEvent(new Event('change'));

        DOM.processBtn.onclick = () => {
            const algo = DOM.algo.value;
            const txt = DOM.mainIn.value;
            let key = DOM.keyIn.value;
            let res = "";

            if (!txt && algo !== 'steganography') {
                showToast("Input text is required.", "error");
                return;
            }

            if (algo === 'steganography') {
                const cvs = document.getElementById('stegoCanvas');
                const ctx = cvs.getContext('2d');
                if (mode === 'encrypt') {
                    if(!DOM.stegoFile.files[0] || !DOM.stegoPayload.value) return showToast("Image and Text required!", "error");
                    const reader = new FileReader();
                    reader.onload = (e) => {
                        const img = new Image();
                        img.onload = () => {
                            cvs.width = img.width; cvs.height = img.height;
                            ctx.drawImage(img, 0, 0);
                            const imgData = ctx.getImageData(0,0,img.width,img.height);
                            const msg = DOM.stegoPayload.value;
                            let bin = ""; for(let i=0; i<msg.length; i++) bin += msg.charCodeAt(i).toString(2).padStart(8,'0');
                            bin += "00000000";
                            if(bin.length > imgData.data.length/4) return showToast("Message too long", "error");
                            let dIdx = 0;
                            for(let i=0; i<bin.length; i++) { if(dIdx%4===3) dIdx++; imgData.data[dIdx] = (imgData.data[dIdx] & 254) | parseInt(bin[i]); dIdx++; }
                            ctx.putImageData(imgData, 0, 0);
                            const link = document.createElement('a'); link.download = 'secret_stego.png'; link.href = cvs.toDataURL(); link.click();
                            DOM.out.innerText = "SUCCESS: Encoded Image Downloaded.";
                            showToast("Encoded Image Downloaded.", "success");
                        }; img.src = e.target.result;
                    }; reader.readAsDataURL(DOM.stegoFile.files[0]);
                } else {
                    if(!DOM.stegoFile.files[0]) return showToast("Select Image", "error");
                    const reader = new FileReader();
                    reader.onload = (e) => {
                        const img = new Image();
                        img.onload = () => {
                            cvs.width = img.width; cvs.height = img.height;
                            ctx.drawImage(img, 0, 0);
                            const data = ctx.getImageData(0,0,img.width,img.height).data;
                            let bin = "", resText = "";
                            for(let i=0; i<data.length; i++) { if(i%4===3) continue; bin += (data[i]&1).toString(); if(bin.length===8) { if(bin==="00000000") break; resText += String.fromCharCode(parseInt(bin, 2)); bin = ""; } }
                            animateText(DOM.out, "DECODED SECRET:\n" + resText);
                            showToast("Image Decoded.", "success");
                        }; img.src = e.target.result;
                    }; reader.readAsDataURL(DOM.stegoFile.files[0]);
                }
                return;
            }

            if (algo === 'rsa') {
                const encryptor = new JSEncrypt({default_key_size: 512});
                const rsaKeyVal = DOM.rsaKeyIn.value.trim();
                if (mode === 'encrypt') {
                    let pubKey = rsaKeyVal;
                    let extra = "";
                    if (!pubKey) { pubKey = encryptor.getPublicKey(); keyCache.rsa = encryptor.getPrivateKey(); updateMemoryStatus(); extra = "\n\n[PRIVATE KEY CACHED]"; encryptor.setPublicKey(pubKey); } 
                    else { encryptor.setPublicKey(pubKey); }
                    const enc = encryptor.encrypt(txt);
                    res = enc ? "CIPHERTEXT:\n" + enc + extra : "FAILED";
                    if(enc) showToast("Encryption Successful", "success"); else showToast("Encryption Failed", "error");
                } else {
                    let privKey = rsaKeyVal || keyCache.rsa;
                    if(!privKey) return showToast("Private Key Required", "error");
                    encryptor.setPrivateKey(privKey);
                    const dec = encryptor.decrypt(txt);
                    res = dec ? "DECRYPTED:\n" + dec : "FAILED";
                    if(dec) showToast("Decryption Successful", "success"); else showToast("Decryption Failed", "error");
                }
            } 
            else if (algo === 'aes') {
                if (mode === 'encrypt') {
                    if(!key) return showToast("Password/Key Required", "error");
                    keyCache.aes = key; updateMemoryStatus();
                    res = CryptoJS.AES.encrypt(txt, key).toString();
                    showToast("Encryption Successful", "success");
                } else {
                    let useKey = key || keyCache.aes;
                    if(!useKey) return showToast("Password/Key Required", "error");
                    try { 
                        const bytes = CryptoJS.AES.decrypt(txt, useKey); 
                        res = bytes.toString(CryptoJS.enc.Utf8) || "FAILED (Wrong Key)";
                        if(res !== "FAILED (Wrong Key)") showToast("Decryption Successful", "success"); else showToast("Wrong Key", "error");
                    } catch(e) { 
                        res = "INVALID"; 
                        showToast("Decryption Failed", "error");
                    }
                }
            }
            else if (algo === 'caesar') {
                const shift = parseInt(key) || 3;
                const s = mode === 'encrypt' ? shift : -shift;
                res = txt.replace(/[a-zA-Z]/g, c => { const b = c >= 'a' ? 97 : 65; return String.fromCharCode(((c.charCodeAt(0) - b + s) % 26 + 26) % 26 + b); });
            }
            else if (algo === 'atbash') {
                res = txt.replace(/[a-zA-Z]/g, c => {
                    const base = c >= 'a' ? 97 : 65;
                    return String.fromCharCode(base + 25 - (c.charCodeAt(0) - base));
                });
            }
            else if (algo === 'vigenere') {
                if (!key) { res = "ERROR: KEY REQUIRED FOR VIGENERE"; showToast("Keyword Required", "error"); }
                else {
                    let k = key.toUpperCase().replace(/[^A-Z]/g, '');
                    if (!k) { res = "ERROR: INVALID KEY"; showToast("Letters Only", "error"); } else {
                        let kIdx = 0;
                        res = txt.replace(/[a-zA-Z]/g, c => {
                            const base = c >= 'a' ? 97 : 65;
                            const shift = k.charCodeAt(kIdx % k.length) - 65;
                            const s = mode === 'encrypt' ? shift : -shift;
                            kIdx++;
                            return String.fromCharCode(((c.charCodeAt(0) - base + s) % 26 + 26) % 26 + base);
                        });
                    }
                }
            }
            else if (algo === 'rail_fence') {
                let rails = parseInt(key);
                if (isNaN(rails) || rails < 2) { res = "ERROR: KEY MUST BE A NUMBER > 1 FOR RAIL FENCE"; showToast("Number > 1 Required", "error"); }
                else {
                    if (mode === 'encrypt') {
                        let fence = Array.from({length: rails}, () => []);
                        let r = 0, dir = 1;
                        for (let char of txt) { fence[r].push(char); r += dir; if (r === 0 || r === rails - 1) dir = -dir; }
                        res = fence.map(row => row.join('')).join('');
                    } else {
                        let fence = Array.from({length: rails}, () => Array(txt.length).fill(null));
                        let r = 0, dir = 1;
                        for (let i = 0; i < txt.length; i++) { fence[r][i] = '*'; r += dir; if (r === 0 || r === rails - 1) dir = -dir; }
                        let idx = 0;
                        for (let row = 0; row < rails; row++) {
                            for (let c = 0; c < txt.length; c++) {
                                if (fence[row][c] === '*' && idx < txt.length) { fence[row][c] = txt[idx++]; }
                            }
                        }
                        let resText = ''; r = 0; dir = 1;
                        for (let c = 0; c < txt.length; c++) { resText += fence[r][c]; r += dir; if (r === 0 || r === rails - 1) dir = -dir; }
                        res = resText;
                    }
                }
            }
            else if (algo === 'playfair') {
                if (!key) { res = "ERROR: KEY REQUIRED FOR PLAYFAIR"; showToast("Keyword Required", "error"); }
                else {
                    let k = key.toUpperCase().replace(/[^A-Z]/g, '').replace(/J/g, 'I');
                    let alphabet = "ABCDEFGHIKLMNOPQRSTUVWXYZ";
                    let gridStr = Array.from(new Set((k + alphabet).split(''))).join('');
                    let grid = [];
                    for (let i=0; i<5; i++) grid.push(gridStr.slice(i*5, i*5+5).split(''));
                    let findPos = (char) => { for (let r=0; r<5; r++) for (let c=0; c<5; c++) if (grid[r][c]===char) return [r,c]; return [0,0]; };

                    let pt = txt.toUpperCase().replace(/[^A-Z]/g, '').replace(/J/g, 'I');
                    if (mode === 'encrypt') {
                        let pairs = [];
                        for(let i=0; i<pt.length; i++) {
                            let a = pt[i], b = pt[i+1];
                            if(b && a===b) { pairs.push([a, 'X']); }
                            else if (b) { pairs.push([a, b]); i++; }
                            else { pairs.push([a, 'X']); }
                        }
                        pt = pairs;
                    } else {
                        let pairs = [];
                        for(let i=0; i<pt.length; i+=2) pairs.push([pt[i], pt[i+1] || 'X']);
                        pt = pairs;
                    }
                    res = "";
                    let shift = mode === 'encrypt' ? 1 : -1;
                    for (let [a,b] of pt) {
                        let [r1,c1] = findPos(a); let [r2,c2] = findPos(b);
                        if (r1===r2) { res += grid[r1][(c1+shift+5)%5] + grid[r2][(c2+shift+5)%5]; }
                        else if (c1===c2) { res += grid[(r1+shift+5)%5][c1] + grid[(r2+shift+5)%5][c2]; }
                        else { res += grid[r1][c2] + grid[r2][c1]; }
                    }
                    if (mode === 'decrypt') {
                        let cleanedRes = "";
                        for (let i = 0; i < res.length; i++) {
                            if (res[i] === 'X' && i > 0 && i < res.length - 1 && res[i-1] === res[i+1]) continue; 
                            if (res[i] === 'X' && i === res.length - 1) continue;
                            cleanedRes += res[i];
                        }
                        res = cleanedRes;
                    }
                }
            }
            else if (algo === 'pigpen') {
                res = txt.toUpperCase(); // True font handles visual translation
            }
            else { 
                res = `[SIMULATION] ${algo.toUpperCase()} RESULT FOR:\n${txt}\n\n(Requires advanced external math library not loaded in this pure JS environment)`; 
            }

            // Disable flashing matrix animation for Pigpen shapes, else use animation
            if (algo === 'pigpen' && !res.includes("ERROR")) {
                DOM.out.innerText = res;
            } else if (!res.includes("ERROR")) {
                animateText(DOM.out, res);
            } else {
                DOM.out.innerText = res;
            }
        };

        const vaultModal = document.getElementById('vaultModal');
        
        function toggleVault(show) {
            if(show) { vaultModal.classList.remove('hidden','pointer-events-none'); setTimeout(()=>vaultModal.classList.remove('opacity-0'), 10); loadFiles(); } 
            else { vaultModal.classList.add('opacity-0','pointer-events-none'); setTimeout(()=>vaultModal.classList.add('hidden'), 300); }
        }

        async function uploadEncryptedFile() {
            const fi = document.getElementById('vaultInput'); 
            const pw = document.getElementById('vaultPass').value;
            if(!fi.files[0] || !pw) return showToast("File and Password required!", "error");
            
            showToast("Encrypting file...", "info");
            
            const reader = new FileReader();
            reader.onload = async (e) => {
                const enc = CryptoJS.AES.encrypt(e.target.result, pw).toString();
                const blob = new Blob([enc],{type:'text/plain'});
                const f = new File([blob], fi.files[0].name+".enc", {type:"text/plain"});
                const fd = new FormData(); fd.append('vaultFile', f);
                try {
                    await fetch('/api/vault/upload', { method:'POST', headers:{'auth-token':token}, body:fd });
                    loadFiles();
                    showToast("File Encrypted & Uploaded to Vault.", "success");
                    fi.value = "";
                    document.getElementById('vaultPass').value = "";
                } catch(err) { showToast("Upload Failed", "error"); }
            }; 
            reader.readAsDataURL(fi.files[0]);
        }

        async function loadFiles() {
            try { 
                const res = await fetch('/api/vault/myfiles', {headers:{'auth-token':token}}); 
                const files = await res.json();
                const list = document.getElementById('vaultList'); 
                list.innerHTML = '';
                
                if(files.length === 0) list.innerHTML = '<div class="text-xs text-[var(--text-muted)] p-2 font-mono">VAULT EMPTY</div>';

                files.forEach(f => { 
                    list.innerHTML += `
                    <div class="flex justify-between items-center p-3 bg-black/40 border border-white/5 mb-2 rounded hover:border-[var(--primary)] transition-colors group">
                        <span class="text-xs text-[var(--text-muted)] truncate w-40 font-mono group-hover:text-[var(--text-main)] transition-colors">${f.originalName}</span>
                        <div class="flex gap-2">
                            <button onclick="downloadAndDecrypt('${f.filename}','${f.originalName}')" class="text-[var(--primary)] text-[9px] border border-[var(--primary)] px-3 py-1 rounded hover:bg-[var(--primary)] hover:text-black font-bold transition-all active:scale-95">DECRYPT</button>
                            <button onclick="deleteFile('${f._id}')" class="text-red-500 text-[9px] border border-red-500 px-3 py-1 rounded hover:bg-red-500 hover:text-black font-bold transition-all active:scale-95">DELETE</button>
                        </div>
                    </div>`; 
                });
            } catch(e){ showToast("Vault Load Error", "error"); }
        }

        async function downloadAndDecrypt(fname, og) {
            const pw = await askPassword(); 
            if(!pw) return;
            
            try {
                const res = await fetch(`/api/vault/file/${fname}?token=${token}`);
                if(!res.ok) throw new Error("Download failed");
                const txt = await res.text();
                const dec = CryptoJS.AES.decrypt(txt, pw).toString(CryptoJS.enc.Utf8);
                if(!dec.startsWith('data:')) throw new Error("Decryption failed");
                const a = document.createElement('a'); a.href = dec; a.download = og.replace('.enc',''); a.click();
                showToast("File Decrypted & Downloaded.", "success");
            } catch(e) { showToast("ACCESS DENIED: INCORRECT PASSWORD", "error"); }
        }

        async function deleteFile(id) {
            const proceed = await askConfirm("WARNING: PERMANENTLY DELETE THIS FILE?");
            if(!proceed) return;
            
            try {
                const res = await fetch(`/api/vault/delete/${id}`, { method: 'DELETE', headers: {'auth-token': token} });
                if(res.ok) { 
                    loadFiles(); 
                    showToast("File Deleted.", "success"); 
                } else { 
                    showToast("Delete Failed", "error"); 
                }
            } catch(e) { showToast("System Error", "error"); }
        }
        
        document.getElementById('copyBtn').onclick = () => {
            navigator.clipboard.writeText(DOM.out.innerText);
            showToast("Copied to clipboard!", "success");
        };
    </script>
</body>
